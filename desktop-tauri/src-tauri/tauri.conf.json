{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SMS Sync",
  "version": "1.0.0",
  "identifier": "com.pwxiao.sms-sync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SMS Sync",
        "width": 420,
        "height": 560,
        "decorations": false,
        "center": true,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 400
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
